                        def _color_minutes(val):
                            try:
                                v = float(val)
                            except Exception:
                                return ""
                            if v < 40:
                                return "background-color: #f94144; color: white"
                            elif v < 90:
                                return "background-color: #f9c74f; color: black"
                            elif v < 200:
