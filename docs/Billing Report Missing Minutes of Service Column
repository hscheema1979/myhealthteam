                        def style_names(df):
                            def _row_style(row):
                                styles = []
                                row_style = color_patient_name(row)
                                for col in df.columns:
                                    if col in name_cols:
                                        styles.append(row_style)
                                    else:
                                        styles.append("")
                                return styles

                            return df.style.apply(lambda r: _row_style(r), axis=1)

                        styled = style_names(df[breakdown_cols])
