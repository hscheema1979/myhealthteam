                    with col3:
                        st.metric("Billed Tasks", coord_summary["billed_tasks"])
                    with col4:
                        st.metric("Paid Tasks", coord_summary["paid_tasks"])
                else:
                    st.info(f"No detailed tasks found for {selected_coordinator}")


# Main execution
if __name__ == "__main__":
