                    "phone_medical_number",
                    "phone_appointment_number",
                    "facility",
                    "provider_name",
                    "coordinator_name",
                    "Last Visit Date",
                    "service_type",
                ]

                breakdown_cols = [
                    col for col in required_columns if col in patients_df.columns
                ]

                def show_styled_table(df, height):
